modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["ffmpeg", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libXrender", "xorg.libXtst", "xorg.libxcb", "xorg.libxshmfence", "nss", "nspr", "at-spi2-atk", "cups", "libdrm", "mesa", "alsa-lib", "dbus", "pango", "cairo", "gtk3", "glib", "expat", "libgbm", "libxkbcommon"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mac App (Remote SDI)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx electron . --no-sandbox --disable-gpu-sandbox"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow]]
name = "Mac App (Remote SDI)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mac-app && npx electron . --no-sandbox --disable-gpu-sandbox"

[workflows.workflow.metadata]
outputType = "vnc"

[[ports]]
localPort = 5904
externalPort = 80

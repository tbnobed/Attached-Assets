{
  "name": "zoomlink",
  "version": "1.0.0",
  "description": "ZoomLink - Zoom to broadcast bridge with NDI, SDI, and per-participant recording",
  "main": "src/main/main.js",
  "scripts": {
    "start": "DYLD_LIBRARY_PATH=./node_modules/grandiose/build/Release:$DYLD_LIBRARY_PATH electron . --no-sandbox --disable-gpu-sandbox",
    "dev": "DYLD_LIBRARY_PATH=./node_modules/grandiose/build/Release:$DYLD_LIBRARY_PATH electron . --no-sandbox --disable-gpu-sandbox",
    "install-sdk": "node scripts/install-zoom-sdk.js",
    "build-addon": "cd zoom-meeting-sdk-addon && npx node-gyp rebuild",
    "build-decklink": "cd decklink-output-addon && npx node-gyp rebuild",
    "link-frameworks": "node scripts/link-electron-frameworks.js",
    "build-app": "bash scripts/build-app.sh",
    "create-icns": "bash scripts/create-icns.sh"
  },
  "keywords": [
    "zoom",
    "iso",
    "ndi",
    "broadcast",
    "electron"
  ],
  "license": "MIT",
  "dependencies": {
    "electron": "^40.6.1",
    "jsonwebtoken": "^9.0.3"
  }
}

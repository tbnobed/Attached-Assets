{
  "name": "zoom-iso-capture",
  "version": "1.0.0",
  "description": "Zoom Video SDK ISO Capture for broadcast production - isolated video/audio feeds with NDI output and local recording",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu-sandbox",
    "dev": "electron . --no-sandbox --disable-gpu-sandbox",
    "install-sdk": "node scripts/install-zoom-sdk.js",
    "build-addon": "cd zoom-meeting-sdk-addon && npx node-gyp rebuild"
  },
  "keywords": [
    "zoom",
    "iso",
    "ndi",
    "broadcast",
    "electron"
  ],
  "license": "MIT",
  "dependencies": {
    "electron": "^40.6.1",
    "jsonwebtoken": "^9.0.3"
  }
}
